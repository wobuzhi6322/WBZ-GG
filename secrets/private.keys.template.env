# Copy this file to: secrets/private.keys.env
# Do NOT commit the copied file.

# PUBG / Steam
PUBG_API_KEY=YOUR_PUBG_API_KEY
PUBG_API_KEY_KAKAO=YOUR_PUBG_KAKAO_API_KEY
STEAM_API_KEY=YOUR_STEAM_API_KEY
PUBG_FETCH_MAX_RETRIES=2
PUBG_FETCH_RETRY_BASE_MS=500
PUBG_MATCH_FETCH_CONCURRENCY=3
PUBG_MATCH_FETCH_HARD_CAP=120
PUBG_BOT_STATS_MAX_MATCH_IDS=8
PUBG_BOT_STATS_CONCURRENCY=1

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (Auth/Profile store)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Backend
DATABASE_URL=sqlite:///./wbz.db
CORS_ORIGINS=["http://localhost:3000"]
APP_NAME=WBZ Backend API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
